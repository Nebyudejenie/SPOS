# Backend configuration (copy to .env for local non-Docker runs)
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=*

# Optional: enables the "Ask Hermes" AI analyst (/api/hermes/ask).
# Without it, that endpoint returns 503 and the rest of the app works normally.
# ANTHROPIC_API_KEY=sk-ant-...

# Option A: discrete connection vars
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=appdb
DB_POOL_MAX=10

# Option B: single URL (overrides the discrete vars above if set)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/appdb
