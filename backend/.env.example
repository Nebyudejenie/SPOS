# Backend configuration (copy to .env for local non-Docker runs)
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=*

# Option A: discrete connection vars
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=appdb
DB_POOL_MAX=10

# Option B: single URL (overrides the discrete vars above if set)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/appdb
